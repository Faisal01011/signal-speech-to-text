# Supabase project URL (used to verify auth JWTs). Find it in
# Project Settings -> API -> Project URL.
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Postgres connection string.
# Find this in your Supabase project: Settings -> Database -> Connection string (URI)
# It looks like:
# postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
#
# If DATABASE_URL is not set, the backend falls back to a local SQLite file
# (local_dev.db) so you can develop without a Supabase project yet.
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# Optional overrides for the Whisper model (see backend/transcriber.py)
# WHISPER_MODEL_SIZE=small.en
# WHISPER_DEVICE=cpu
# WHISPER_COMPUTE_TYPE=int8
